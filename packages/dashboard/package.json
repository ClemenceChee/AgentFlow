{
  "name": "agentflow-dashboard",
  "version": "0.8.3",
  "description": "Real-time monitoring dashboard for AgentFlow - Visualize agent execution graphs and performance",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agentflow-dashboard": "./bin/dashboard.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/server.ts --format esm,cjs --clean && npm run build:client",
    "build:client": "vite build",
    "dev": "tsx src/server.ts",
    "dev:client": "vite",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:performance": "vitest run tests/performance/ --testTimeout=120000",
    "test:e2e": "playwright test",
    "test:e2e:server": "tsx tests/e2e/test-server.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:performance && npm run test:e2e",
    "test:ci": "npm run test:unit && npm run test:integration",
    "prepublishOnly": "npm run build && npm run test:ci"
  },
  "dependencies": {
    "agentflow-core": "^0.8.0",
    "chokidar": "^3.5.3",
    "express": "^4.18.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/express": "^4.17.21",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.0.0",
    "get-port": "^7.0.0",
    "supertest": "^7.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.0",
    "ws": "^8.16.0"
  },
  "keywords": [
    "agentflow",
    "dashboard",
    "monitoring",
    "ai",
    "agent",
    "tracing",
    "observability",
    "real-time"
  ],
  "license": "Apache-2.0 WITH Commons-Clause-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ClemenceChee/AgentFlow.git"
  },
  "homepage": "https://github.com/ClemenceChee/AgentFlow#readme",
  "bugs": {
    "url": "https://github.com/ClemenceChee/AgentFlow/issues"
  },
  "author": "Clemence Chee",
  "engines": {
    "node": ">=20"
  }
}
