{
  "name": "agentflow-dashboard",
  "version": "0.2.0",
  "description": "Real-time monitoring dashboard for AgentFlow - Visualize agent execution graphs and performance",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agentflow-dashboard": "./bin/dashboard.js"
  },
  "files": [
    "dist",
    "bin",
    "public"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --clean && npm run build:public",
    "build:public": "cp -r public dist/",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "agentflow-core": "^0.6.3",
    "chokidar": "^3.5.3",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0"
  },
  "keywords": [
    "agentflow",
    "dashboard",
    "monitoring",
    "ai",
    "agent",
    "tracing",
    "observability",
    "real-time"
  ],
  "license": "MIT"
}
