{
  "name": "agentflow-storage",
  "version": "0.1.2",
  "description": "Persistent storage and querying for AgentFlow - Store and analyze agent execution history",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "agentflow-query": "./bin/query.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chokidar": "^3.5.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "agentflow",
    "storage",
    "database",
    "sqlite",
    "querying",
    "analytics",
    "tracing",
    "history"
  ],
  "license": "MIT"
}
