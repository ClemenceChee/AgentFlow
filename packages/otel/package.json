{
  "name": "agentflow-otel",
  "private": true,
  "version": "0.1.0",
  "description": "OpenTelemetry exporter for AgentFlow - Export agent execution traces to OTel-compatible backends",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "agentflow-core": "^0.8.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/instrumentation": "^0.215.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.28.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "keywords": [
    "agentflow",
    "opentelemetry",
    "otel",
    "observability",
    "tracing",
    "ai",
    "agent",
    "monitoring",
    "genai",
    "llm"
  ],
  "license": "Apache-2.0 WITH Commons-Clause-1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ClemenceChee/AgentFlow.git"
  },
  "homepage": "https://github.com/ClemenceChee/AgentFlow#readme",
  "bugs": {
    "url": "https://github.com/ClemenceChee/AgentFlow/issues"
  },
  "author": "Clemence Chee",
  "engines": {
    "node": ">=20"
  }
}
