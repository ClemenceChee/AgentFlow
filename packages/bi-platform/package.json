{
  "name": "agentflow-bi-platform",
  "version": "0.1.0",
  "description": "Business Intelligence Platform — bridges SOMA/AgentFlow/OpsIntel for business consumers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --clean && npm run build:client",
    "build:server": "tsup src/index.ts src/server.ts --format esm --clean",
    "build:client": "vite build",
    "dev": "tsx src/server.ts",
    "dev:client": "vite",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:rollback": "tsx src/db/rollback.ts"
  },
  "dependencies": {
    "agentflow-core": "*"
  },
  "peerDependencies": {
    "pg": "^8.13.0",
    "ioredis": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.1"
  }
}
