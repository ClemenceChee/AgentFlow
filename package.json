{
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check --diagnostic-level=error packages/ tests/",
    "lint:fix": "biome check --write packages/ tests/",
    "typecheck": "tsc -b",
    "docs:dev": "npm run start --prefix docs",
    "docs:build": "npm run build --prefix docs",
    "docs:serve": "npm run serve --prefix docs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^25.5.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
